        "# Print a summary of the export process\n",
        "print(\"===================================\")\n",
        "print(f\"Done! Created {OUTPUT_FILE}\")\n",
        "print(\"Total rows:\", len(df))\n",
        "print(\"File saved at:\", os.path.abspath(OUTPUT_FILE)) # Display the absolute path to the file\n",
        "print(\"===================================\")"
